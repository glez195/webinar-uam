    <div class="wbr-rev-row"><div class="wbr-rev-lbl">Inscripción</div><div class="wbr-rev-val">${st.inscripcion==="si"?"Sí ("+st.aprobacion+")":st.inscripcion==="no"?"No":"—"}</div></div>
