/* ── RENDER PRINCIPAL ─────────────────────────────────────────── */
function render(){
  const ms=maxStep();
  if(st.submitted){
    document.getElementById("wbr-stepper").innerHTML="";
    document.getElementById("wbr-body").innerHTML="<div style='padding:0 1.25rem'>"+renderSuccess()+"</div>";
    document.getElementById("wbr-nav").innerHTML="";
    const rb=document.getElementById("wbr-reset-btn");
    if(rb)rb.addEventListener("click",function(){
      Object.assign(st,{step:1,submitted:false,nombre:"",economico:"",departamento:"",correo:"",correoConfirm:"",telefono:"",tema:"",descripcion:"",fecha:"",hora:"",duracion:"",panelistas:[{nombre:"",correo:""}],grabacion:"",grabTipo:"nube",dryRun:"",dryRunTipo:"dia",inscripcion:"",aprobacion:"auto",bannerName:"",solicitud:"",selDate:null,availResult:""});
      render();
    });
    return;
  }

  renderStepper();

  let body="";
  if(st.step===1)body=renderStep1();
  else if(st.step===2)body=renderStep2();
  else if(st.step===3)body=renderStep3();
  else if(st.step===4&&st.inscripcion!=="no")body=renderStep4();
  else body=renderStep5();
  document.getElementById("wbr-body").innerHTML=body;

  const ok=canNext(); const isLast=st.step===ms;
  document.getElementById("wbr-nav").innerHTML=`<div style="display:flex;justify-content:space-between;align-items:center">
    ${st.step>1?`<button class="wbr-btn-sm" id="wbr-prev-btn" style="font-size:13px;padding:8px 16px">&#8592; Anterior</button>`:`<div></div>`}
    ${isLast
      ?`<button id="wbr-send-btn" style="opacity:1;background:#0E72ED;color:#fff;border:none;border-radius:8px;padding:10px 24px;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit">Enviar solicitud</button>`
      :`<button id="wbr-next-btn" style="opacity:${ok?1:0.45};background:#0E72ED;color:#fff;border:none;border-radius:8px;padding:10px 24px;font-size:14px;font-weight:600;cursor:${ok?"pointer":"default"};font-family:inherit">Siguiente &#8594;</button>`
    }
  </div>`;

  /* Bind botones de navegación */
  const prevBtn=document.getElementById("wbr-prev-btn");
  if(prevBtn)prevBtn.addEventListener("click",prevStep);

  const nextBtn=document.getElementById("wbr-next-btn");
  if(nextBtn)nextBtn.addEventListener("click",function(){if(canNext())nextStep();});

  /* Bind envío Make */
  bindEnviar();

  /* Bind específicos por paso */
  if(st.step===2)bindCal();
  if(st.step===3)bindPanelistas();
  if(st.step===4&&st.inscripcion!=="no")bindStep4();
}

