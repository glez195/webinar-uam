/* ── ENVÍO A MAKE VÍA WEBHOOK ─────────────────────────────────── */
function bindEnviar(){
  const btn=document.getElementById("wbr-send-btn");
  if(!btn)return;
  btn.addEventListener("click",async function(){
    btn.disabled=true;
    btn.textContent="Enviando...";
    const fecha=st.fecha?st.fecha.split("-").reverse().join("/"):"—";
    const folio="WEB-"+(st.economico||"000")+"-"+(st.fecha||"00000000").replace(/-/g,"");
    const pans=st.panelistas.filter(p=>p.correo);
    const payload={
      folio:        folio,
      nombre:       st.nombre,
      economico:    st.economico,
      departamento: st.departamento,
      correo:       st.correo,
      telefono:     st.telefono,
      tema:         st.tema,
      descripcion:  st.descripcion,
      fecha:        fecha,
      hora:         st.hora,
      duracion:     st.duracion,
      grabacion:    st.grabacion,
      grabTipo:     st.grabacion==="si"?st.grabTipo:"",
      dryRun:       st.dryRun,
      dryRunTipo:   st.dryRun==="si"?st.dryRunTipo:"",
      inscripcion:  st.inscripcion,
      aprobacion:   st.inscripcion==="si"?st.aprobacion:"",
      bannerNombre: st.bannerName||"",
      solicitud:    st.solicitud||"",
      panelistas:   pans,
      panelistas_texto: pans.map(p=>p.nombre+" <"+p.correo+">").join(", ")||"Ninguno",
      asunto:       "[NUEVA RESERVA] - Webinar Licencia 500 - "+fecha,
      timestamp:    new Date().toISOString()
    };
    try{
      const res=await fetch(WEBHOOK_URL,{
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body:JSON.stringify(payload)
      });
      if(res.ok){st.submitted=true;render();}
      else throw new Error("HTTP "+res.status);
    }catch(e){
      btn.disabled=false;
      btn.textContent="Enviar solicitud";
      alert("Error al enviar. Verifica tu conexión e intenta de nuevo.\n("+e.message+")");
    }
  });
}

